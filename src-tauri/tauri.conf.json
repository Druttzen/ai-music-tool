{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Music Creator Studio",
  "version": "0.13.7",
  "identifier": "com.djmad.aimusiccreator.studio",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Music Creator Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ai-sidecar"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
