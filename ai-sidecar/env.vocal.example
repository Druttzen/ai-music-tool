# Copy to ai-sidecar/.env.vocal and set paths to your user-owned voice models.
# Restart the sidecar after editing. Existing process env vars take precedence.

# RVC — local model file
# AIMC_RVC_MODEL=C:\models\my-voice.pth
# AIMC_RVC_INDEX=C:\models\my-voice.index

# RVC — external API (python -m rvc_python api -p 5050)
# AIMC_RVC_API_URL=http://127.0.0.1:5050

# DiffSinger — CLI bridge (see scripts/diffsinger_bridge_example.py)
# AIMC_DIFFSINGER_CMD=python ai-sidecar/scripts/diffsinger_bridge_example.py
# AIMC_DIFFSINGER_MODEL_DIR=C:\models\diffsinger

# DiffSinger — HTTP service
# AIMC_DIFFSINGER_URL=http://127.0.0.1:8765
