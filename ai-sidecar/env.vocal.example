# Copy to ai-sidecar/.env.vocal and set paths to your user-owned voice models.
# Restart the sidecar after editing. Existing process env vars take precedence.

# RVC — local model file
# AIMC_RVC_MODEL=C:\models\my-voice.pth
# AIMC_RVC_INDEX=C:\models\my-voice.index

# RVC — external API (python -m rvc_python api -p 5050)
# AIMC_RVC_API_URL=http://127.0.0.1:5050

# DiffSinger — OpenVPI (recommended)
# AIMC_DIFFSINGER_ROOT=C:\models\DiffSinger
# AIMC_DIFFSINGER_VAR_EXP=my_variance_ckpt
# AIMC_DIFFSINGER_ACOUSTIC_EXP=my_acoustic_ckpt
# AIMC_DIFFSINGER_PYTHON=C:\models\DiffSinger\.venv\Scripts\python.exe
# AIMC_DIFFSINGER_SPK=speaker_name
# AIMC_DIFFSINGER_LANG=english
# AIMC_DIFFSINGER_KEY=0

# DiffSinger — CLI bridge (optional; uses OpenVPI when ROOT is set)
# AIMC_DIFFSINGER_CMD=python ai-sidecar/scripts/diffsinger_bridge_example.py

# DiffSinger — HTTP service
# AIMC_DIFFSINGER_URL=http://127.0.0.1:8765

# Optional genre classifier override (DistilHuBERT 18-genre model)
# AIMC_GENRE_MODEL=MarekCech/GenreVim-Music-Classification-DistilHuBERT

# Optional MFA alignment for guide vocal → DiffSinger .ds timing
# AIMC_MFA_BIN=mfa
# AIMC_MFA_MODEL=english_mfa
# AIMC_MFA_DICT=english_mfa
