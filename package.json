{
  "name": "ai-music-tool",
  "version": "0.6.0",
  "description": "AI Music Creator Visual Prompt Engine",
  "author": "DJ M@D",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "debug": "node --inspect=9241 node_modules/next/dist/bin/next dev",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "lint": "eslint . --max-warnings 0",
    "check": "npm run lint && npm run build",
    "build": "next build",
    "electron": "electron .",
    "predist": "node scripts/prep-electron-dist.cjs",
    "dist": "npm run build && npm run predist && electron-builder",
    "dis": "npm run dist"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "electron": "latest",
    "electron-builder": "latest"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "build": {
    "appId": "com.djmad.aimusiccreator",
    "productName": "AI Music Creator",
    "files": [
      "main.js",
      "out/**/*",
      "icon.ico",
      "build/AI_Music_Creator_README.pdf"
    ],
    "directories": {
      "buildResources": "build",
      "output": "electron-dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
