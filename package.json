{
  "name": "ai-music-tool",
  "version": "0.5.1",
  "description": "AI Music Creator Visual Prompt Engine",
  "author": "DJ M@D",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "electron": "latest",
    "electron-builder": "latest"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "build": {
    "appId": "com.djmad.aimusiccreator",
    "productName": "AI Music Creator",
    "files": [
      "main.js",
      "out/**/*",
      "icon.ico",
      "build/AI_Music_Creator_README.pdf"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
