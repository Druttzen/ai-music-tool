{
  "name": "ai-music-tool",
  "version": "0.18.0",
  "description": "AI Music Creator — Suno prompts, local track analyzer, EBU R128 LUFS meter, and studio WAV export",
  "author": "DJ M@D",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-with-sidecar.ps1",
    "dev:web": "next dev",
    "debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-with-sidecar.ps1 -Inspect",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "cleanup:dist": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-locked-electron-dist.ps1",
    "cleanup:dist:admin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-cleanup-elevated.ps1",
    "cleanup:sudo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/enable-sudo-and-cleanup.ps1",
    "cleanup:dist:sudo": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"sudo powershell -NoProfile -ExecutionPolicy Bypass -File scripts/cleanup-locked-electron-dist.ps1\"",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:smoke": "node scripts/run-sidecar-smoke.cjs",
    "test:smoke:stems": "node scripts/run-sidecar-smoke-stems.cjs",
    "test:smoke:vocal": "node scripts/run-sidecar-smoke-vocal.cjs",
    "test:smoke:generate": "node scripts/run-sidecar-smoke-generate.cjs",
    "sync:suno-catalog": "node scripts/sync-suno-catalog.cjs",
    "import:awesome-suno": "node scripts/import-awesome-suno-concepts.cjs",
    "sync:version": "node scripts/sync-product-version.cjs",
    "prebuild": "node scripts/sync-product-version.cjs",
    "bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-toolchains.ps1",
    "bootstrap:buildtools": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-toolchains.ps1 -WithBuildTools",
    "sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-sidecar.ps1",
    "sidecar:stems": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-sidecar-stems.ps1",
    "sidecar:vocal-ml": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-sidecar-vocal-ml.ps1",
    "sidecar:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-sidecar-generate.ps1",
    "sidecar:fg": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-sidecar.ps1 -Foreground -IdleExitSec 0",
    "sidecar:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-with-sidecar.ps1 -WatchOnly",
    "sidecar:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-sidecar.ps1",
    "build:sidecar": "node scripts/build-sidecar-bundle.cjs",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-sidecar-binary.ps1 && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-with-sidecar.ps1 -Tauri",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-sidecar-binary.ps1 && cd src-tauri && cargo tauri build",
    "check": "npm run test && npm run lint && npm run build",
    "build": "next build",
    "electron": "electron .",
    "build:readme-pdf": "node scripts/generate-readme-pdf.cjs",
    "prepare:electron-dist": "node scripts/prep-electron-dist.cjs",
    "dist": "npm run build && npm run build:readme-pdf && npm run prepare:electron-dist && node scripts/run-electron-builder.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lamejs": "^1.2.1",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "wavesurfer.js": "^7.12.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "fake-indexeddb": "^6.2.5",
    "pdfkit": "^0.19.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "build": {
    "appId": "com.djmad.aimusiccreator",
    "productName": "AI Music Creator",
    "files": [
      "main.js",
      "preload.js",
      "out/**/*",
      "icon.ico"
    ],
    "extraResources": [
      "build/AI_Music_Creator_README.pdf"
    ],
    "directories": {
      "buildResources": "build",
      "output": "electron-dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Druttzen",
        "repo": "ai-music-tool",
        "releaseType": "release"
      }
    ]
  }
}
